#!/bin/bash -l

# Installs a GitHub Actions runner agent as a service for the user "runner". Run as root.
#
# Usage:
# GITHUB_TOKEN=<token> RUNNER_NAME=<name> ./install-runner-agent

set -e

if [ -z "$GITHUB_TOKEN" ]; then fatal "GITHUB_TOKEN environment variable is not set"; fi
if [ -z "$RUNNER_NAME" ]; then fatal "RUNNER_NAME environment variable is not set"; fi

echo "Generating a registration token..."

export RUNNER_TOKEN=$(curl -s -X POST https://api.github.com/orgs/mynewsdesk/actions/runners/registration-token -H "accept: application/vnd.github+json" -H "authorization: token ${GITHUB_TOKEN}" | jq -r '.token')

if [ "null" == "$RUNNER_TOKEN" -o -z "$RUNNER_TOKEN" ]; then fatal "Failed to get a token"; fi

echo
echo "Configuring runner..."

mkdir -p /home/runner/actions-runner
cd /home/runner/actions-runner
wget -q -O - https://github.com/actions/runner/releases/download/v2.329.0/actions-runner-linux-x64-2.329.0.tar.gz | tar xz
chown -R runner .

sudo -u runner ./config.sh --unattended --url https://github.com/mynewsdesk --token $RUNNER_TOKEN --name $RUNNER_NAME --labels linux,amd64,hetzner,ax52,self-hosted,high-cpu

echo
echo "Configuring as a service..."

./svc.sh install runner

# NOTE: To enable rbenv, volta etc inside our github runners we need to modify the runsvc.sh script.
# However, this file is ocasionally updated by GitHub when updating the runner which suddenly breaks
# our runners since they can't find ruby, node, yarn etc. To work around this we create a copy of the
# runsvc.sh script and modify that one instead, and then point the systemd service to that script.

cp /home/runner/actions-runner/runsvc.sh /home/runner/actions-runner/runsvc-with-profile.sh
chmod +x /home/runner/actions-runner/runsvc-with-profile.sh
chown runner:runner /home/runner/actions-runner/runsvc-with-profile.sh

mkdir -p /etc/systemd/system/actions.runner.mynewsdesk.$RUNNER_NAME.service.d
echo "
[Service]
ExecStart=
ExecStart=/home/runner/actions-runner/runsvc-with-profile.sh
" > /etc/systemd/system/actions.runner.mynewsdesk.$RUNNER_NAME.service.d/override.conf

# Inject sourcing of .profile below '# insert anything to setup env when running as a service. Assumed to be line 16':
# https://github.com/actions/runner/blob/8db8bbe13a0dabc165d0ff19a1ecb85a4fe86dd8/src/Misc/layoutbin/runsvc.sh#L16
sed -i "16i # added by mynewsdesk install script:\nsource /home/runner/.profile\n" /home/runner/actions-runner/runsvc-with-profile.sh

./svc.sh start

echo "Done setting up runner agent! 🚀"
